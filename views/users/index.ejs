<%- include('../partials/header') %>

<div class="container my-4">
    <h2 class="mb-4">User Directory</h2>
    <p>Page by Tianxiang Huang</p>
    <p>This page showcases a List/View application utilizing Epress&EJS</p>
    <p>Data is pulled from a JSON file.</p>
    <p>Please note, the pictures and info were generated by third party APIs and do not reflect real individuals.</p>
    <table class="table table-hover table-striped">
        <thead class="thead-dark">
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(function(user){ %>
                <tr>
                     <td><a href="/users/view/<%= user.id %>"><%= user.first_name %></a></td>
                     <td><%= user.last_name %></td>
                     <td><%= user.email %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
